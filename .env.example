# .env.example — Copy this to .env and adjust for your system.
# See plans/M0/M0.9-docker-env.md for details.

# Path to the Wealthfolio SQLite database on the HOST.
# The container mounts this file read-only at /wealthfolio/ledger.db.
#
# macOS (default, no override needed):
#   WEALTHFOLIO_DB_PATH=/Users/<you>/Library/Application Support/Wealthfolio/ledger.db
#
# Linux:
#   WEALTHFOLIO_DB_PATH=/home/<you>/.local/share/Wealthfolio/ledger.db
#
# Windows (WSL path):
#   WEALTHFOLIO_DB_PATH=/mnt/c/Users/<you>/AppData/Roaming/Wealthfolio/ledger.db

# WEALTHFOLIO_DB_PATH=/Users/mrihal/Library/Application Support/Wealthfolio/ledger.db
